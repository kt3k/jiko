{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "import-data": "deno run -A scripts/import-csv.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.39",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/json": "jsr:@std/json@^1",
    "@std/streams/": "jsr:/@std/streams@^1/",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.2",
    "chart.js": "npm:chart.js@^4.5.1",
    "fresh": "jsr:@fresh/core@^2.2.2",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "vite": "npm:vite@^7.1.3",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
